theme_override_constants/separation = 0

[node name="FoldableContainer5" type="FoldableContainer" parent="Toolbar/Options/Help/Troubleshooting/TabContainer/Model/VBoxContainer" unique_id=1982738231]
layout_mode = 2
size_flags_horizontal = 3
folded = true
title = "The fingers look very terrible and buggy"
title_text_overrun_behavior = 1

[node name="Label" type="Label" parent="Toolbar/Options/Help/Troubleshooting/TabContainer/Model/VBoxContainer/FoldableContainer5" unique_id=369862054]
visible = false
layout_mode = 2
text = "This is likely because of how your model is rotated, make it so the palm is facing downwards and the fingers should try to match the rotation of the reference model as close as possible

If it looks worse in first person than in third person, it may require a custom arms model which has been adjusted, which is currently not supported"
autowrap_mode = 3

[node name="FoldableContainer13" type="FoldableContainer" parent="Toolbar/Options/Help/Troubleshooting/TabContainer/Model/VBoxContainer" unique_id=240903027]
layout_mode = 2
size_flags_horizontal = 3
folded = true
title = "My character's arms/legs/body part look so weird"
title_text_overrun_behavior = 1

[node name="Label" type="Label" parent="Toolbar/Options/Help/Troubleshooting/TabContainer/Model/VBoxContainer/FoldableContainer13" unique_id=606264877]
visible = false
layout_mode = 2
text = "There are likely two reasons for this

1: You forgot to name some bones or some bones aren't named properly, check them again

2: The default pose you have is not correct, keep in mind that the application expects a T-Pose, not for the funnies, given that's the best way for the model to work as intended in the game"
autowrap_mode = 3

[node name="FoldableContainer14" type="FoldableContainer" parent="Toolbar/Options/Help/Troubleshooting/TabContainer/Model/VBoxContainer" unique_id=1452325762]
layout_mode = 2
size_flags_horizontal = 3
folded = true
title = "My character's feet sink into the ground sometimes"
title_text_overrun_behavior = 1

[node name="Label" type="Label" parent="Toolbar/Options/Help/Troubleshooting/TabContainer/Model/VBoxContainer/FoldableContainer14" unique_id=364071133]
visible = false
layout_mode = 2
text = "This tends to happen if your character has a pretty different armature when it comes to legs, the best fix would be to make the bones match the reference, although this is not always possible to do on some models"
autowrap_mode = 3

[node name="FoldableContainer15" type="FoldableContainer" parent="Toolbar/Options/Help/Troubleshooting/TabContainer/Model/VBoxContainer" unique_id=746550301]
layout_mode = 2
size_flags_horizontal = 3
folded = true
title = "My character deforms oddly in game"
title_text_overrun_behavior = 1

[node name="Label" type="Label" parent="Toolbar/Options/Help/Troubleshooting/TabContainer/Model/VBoxContainer/FoldableContainer15" unique_id=215856662]
visible = false
layout_mode = 2
text = "This can happen if for example your character has very few spine bones, and the spine is very short, so you can try adding bones without any weights before in reasonable spots to try to make it look better"
autowrap_mode = 3

