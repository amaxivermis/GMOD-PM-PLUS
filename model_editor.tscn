[node name="Rename" type="HBoxContainer" parent="Panels/Control/TabContainer/Skeleton/Skeleton/Renaming/VBoxContainer" unique_id=1579056501]
layout_mode = 2
tooltip_text = "The application will analyse the armature and try to rename the bones to the Valve Biped structure. This is an important action to do.

This is estimated to work 90% of the time, the spine bones are more likely to require some renaming. Some armatures with unusual naming or structures may not work with this method

Some armatures that have bones parented in a way that the head doesn't lead up to the pelvis bone by going up may require manual ordering here"

[node name="Label" type="Label" parent="Panels/Control/TabContainer/Skeleton/Skeleton/Renaming/VBoxContainer/Rename" unique_id=1173928599]
layout_mode = 2
text = "Rename Automatically"

