theme_override_constants/separation = 0

[node name="FoldableContainer2" type="FoldableContainer" parent="Toolbar/Options/Help/Troubleshooting/TabContainer/Editor/VBoxContainer" unique_id=1814490378]
layout_mode = 2
size_flags_horizontal = 3
folded = true
title = "I got a warning saying the bones weren't renamed"
title_text_overrun_behavior = 1

[node name="Label" type="Label" parent="Toolbar/Options/Help/Troubleshooting/TabContainer/Editor/VBoxContainer/FoldableContainer2" unique_id=761086694]
visible = false
layout_mode = 2
text = "This is because the amount of bones that have a name that match a certain body part may be too much or too little, if too little you may need to make some changes to your armature, if too many the easiest way is to just rename some of the bones in the area to a gibberish name such as \"feiadwfg\" that doesn't include what the body part is"
autowrap_mode = 3

[node name="FoldableContainer10" type="FoldableContainer" parent="Toolbar/Options/Help/Troubleshooting/TabContainer/Editor/VBoxContainer" unique_id=272241173]
layout_mode = 2
size_flags_horizontal = 3
folded = true
title = "I reposed the character, but the results are a bit weird"
title_text_overrun_behavior = 1

[node name="Label" type="Label" parent="Toolbar/Options/Help/Troubleshooting/TabContainer/Editor/VBoxContainer/FoldableContainer10" unique_id=991085162]
visible = false
layout_mode = 2
text = "You can manually recorrect the rotations, but the repose tool may not work well on all models, especially ones that don't follow normal conventions"
autowrap_mode = 3

[node name="FoldableContainer3" type="FoldableContainer" parent="Toolbar/Options/Help/Troubleshooting/TabContainer/Editor/VBoxContainer" unique_id=1369715881]
layout_mode = 2
size_flags_horizontal = 3
folded = true
title = "The character when I import is sideways or not up"
title_text_overrun_behavior = 1

[node name="Label" type="Label" parent="Toolbar/Options/Help/Troubleshooting/TabContainer/Editor/VBoxContainer/FoldableContainer3" unique_id=2115327165]
visible = false
layout_mode = 2
text = "This tends to happen if you are using someone else's character, if this is happening you need to make sure the model is already facing up and the rotations have been applied or you will run into bugs"
autowrap_mode = 3

[node name="Compilation" type="ScrollContainer" parent="Toolbar/Options/Help/Troubleshooting/TabContainer" unique_id=2003092689]
visible = false
layout_mode = 2
metadata/_tab_index = 1

[node name="VBoxContainer" type="VBoxContainer" parent="Toolbar/Options/Help/Troubleshooting/TabContainer/Compilation" unique_id=856662700]
layout_mode = 2
size_flags_horizontal = 3
theme_override_constants/separation = 0

[node name="FoldableContainer" type="FoldableContainer" parent="Toolbar/Options/Help/Troubleshooting/TabContainer/Compilation/VBoxContainer" unique_id=902533274]
layout_mode = 2
size_flags_horizontal = 3
folded = true
title = "When I hit compile, VTFEdit opens up, and then crashes..."
title_text_overrun_behavior = 1

[node name="Label" type="Label" parent="Toolbar/Options/Help/Troubleshooting/TabContainer/Compilation/VBoxContainer/FoldableContainer" unique_id=1721899170]
visible = false
layout_mode = 2
text = "If this is happening, you most likely set the VTFCmd path to VTFEdit instead of VTFCmd, make sure you are setting the path to VTFCmd instead, that is very important, if you did set VTFCmd, I don't know what happened"
autowrap_mode = 3

[node name="FoldableContainer5" type="FoldableContainer" parent="Toolbar/Options/Help/Troubleshooting/TabContainer/Compilation/VBoxContainer" unique_id=118998167]
layout_mode = 2
size_flags_horizontal = 3
folded = true
title = "I got \"ERROR: Rotation constraint on bone X which has no parent!!!\" when I compiled"
title_text_overrun_behavior = 1

[node name="Label" type="Label" parent="Toolbar/Options/Help/Troubleshooting/TabContainer/Compilation/VBoxContainer/FoldableContainer5" unique_id=1781604479]
visible = false
layout_mode = 2
text = "If you character has two pelvis bones, this is most likely the reason why this error is happening, make sure the top one which isn't really the pelvis bone is renamed to something gibberish and rename the bones again"
autowrap_mode = 3

[node name="FoldableContainer7" type="FoldableContainer" parent="Toolbar/Options/Help/Troubleshooting/TabContainer/Compilation/VBoxContainer" unique_id=301619508]
layout_mode = 2
size_flags_horizontal = 3
folded = true
title = "I get an error saying a folder wasn't deleted"
title_text_overrun_behavior = 1

[node name="Label" type="Label" parent="Toolbar/Options/Help/Troubleshooting/TabContainer/Compilation/VBoxContainer/FoldableContainer7" unique_id=2087642174]
visible = false
layout_mode = 2
text = "This is because of an existing folder in your addons folder, if this is the case there may be file permission issues, but the easiest way to fix this for your current session is to delete the folder and recompile the addon"
autowrap_mode = 3

[node name="FoldableContainer4" type="FoldableContainer" parent="Toolbar/Options/Help/Troubleshooting/TabContainer/Compilation/VBoxContainer" unique_id=440515667]
layout_mode = 2
size_flags_horizontal = 3
folded = true
title = "I got an error about the jigglebones being in the incorrect order"
title_text_overrun_behavior = 1

[node name="Label" type="Label" parent="Toolbar/Options/Help/Troubleshooting/TabContainer/Compilation/VBoxContainer/FoldableContainer4" unique_id=142063569]
visible = false
layout_mode = 2
text = "The start index should be a child reachable somewhere as the final index"
autowrap_mode = 3

