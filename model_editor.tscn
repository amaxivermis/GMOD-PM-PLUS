text = "Rename"

[node name="Repose" type="HBoxContainer" parent="Panels/Control/TabContainer/Skeleton/Skeleton/Renaming/VBoxContainer" unique_id=139022856]
layout_mode = 2
tooltip_text = "This automatically will make your character T-Pose, which is important for reason other than 'memes' in Gmod. Only do this action once the bones have been renamed

-This doesn't correct the arm rotation nor the finger poses, you need to rotate them manually if you have fingers and make sure they are as intended"

